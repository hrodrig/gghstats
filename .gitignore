# Deny-all by default
*
.*

# Allowlist: repository metadata and top-level project files
!.gitignore
!.env.example
!.dockerignore
!.goreleaser
!.goreleaser.yml
!.goreleaser.yaml
!.github/
!.github/**
!Dockerfile
!Dockerfile.release
!Makefile
!README.md
!VERSION
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!AGENTS.md
!codecov.yml
!docker-compose.yml
!go.mod
!go.sum

# Allowlist: source trees
!cmd/
!cmd/**
!internal/
!internal/**
!web/
!web/**
!assets/
!assets/**
!contrib/
!contrib/**
contrib/man/man1/*.gz

# Platform tests (Ansible); local inventory with secrets
!testing/
!testing/**
testing/platforms/inventory/hosts.yml
# Persist data/ in repo (placeholder only); never commit the SQLite DB.
!data/
!.keep
!**/.keep

# Keep common generated/local artifacts ignored
.DS_Store
*.db
data/*.db
*.db-shm
*.db-wal
/gghstats

# OpenBSD port: distinfo requires release tarballs; generate with make makesum in ports tree (not in repo)
contrib/openbsd/port/distinfo
