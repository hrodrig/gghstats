# Deny-all by default
*
.*

# Allowlist: repository metadata and top-level project files
!.gitignore
!.env.example
!.dockerignore
!.goreleaser
!.goreleaser.yml
!.goreleaser.yaml
!.github/
!.github/**
!Dockerfile
!Dockerfile.release
!Makefile
!README.md
!VERSION
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!docker-compose.yml
!docker-compose.prod.yml
!go.mod
!go.sum

# Allowlist: source trees
!cmd/
!cmd/**
!internal/
!internal/**
!web/
!web/**
!assets/
!assets/**
!charts/
!charts/**
# Persist data/ in repo (placeholder only); never commit the SQLite DB.
!data/
!.keep
!**/.keep

# Keep common generated/local artifacts ignored
.DS_Store
*.db
data/*.db
*.db-shm
*.db-wal
/gghstats
