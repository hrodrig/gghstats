# Managed by Ansible (gghstats platform tests). See contrib/gghstats.env.example.
GGHSTATS_GITHUB_TOKEN='{{ gghstats_github_token }}'
GGHSTATS_DB={{ gghstats_data_dir }}/gghstats.db
GGHSTATS_HOST=127.0.0.1
GGHSTATS_PORT={{ gghstats_port | default(8080) }}
GGHSTATS_FILTER='{{ gghstats_filter }}'
GGHSTATS_SYNC_INTERVAL=1h
GGHSTATS_SYNC_ON_STARTUP={{ gghstats_sync_on_startup | default('false') }}
GGHSTATS_INCLUDE_PRIVATE=false
GGHSTATS_DEFAULT_LOCALE=en
GGHSTATS_ENABLED_LOCALES=en
