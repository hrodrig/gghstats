# gghstats — LOCAL dev / smoke test only. Copy to ".env" in this clone. Do not commit .env (gitignored).
#
# Production server: use gghstats-selfhosted — copy run/common/.env.example to ${GGHSTATS_HOST_DATA}/.env
#   https://github.com/hrodrig/gghstats-selfhosted

# Required for `gghstats serve` and for dev Docker Compose in this repo (docker-compose.yml).
# GitHub scopes: see README.md "Token setup" (classic repo vs public_repo; fine-grained permissions).
GGHSTATS_GITHUB_TOKEN=

# Override GitHub API root (default https://api.github.com). Use for GitHub Enterprise or tests.
# GGHSTATS_GITHUB_API_BASE_URL=

# --- Optional (Go binary defaults in parentheses) ---

# SQLite database path
GGHSTATS_DB=./data/gghstats.db

# HTTP bind address and port (127.0.0.1 = localhost only; Docker/Compose must use 0.0.0.0)
GGHSTATS_HOST=127.0.0.1
GGHSTATS_PORT=8080

# Repo filter: * = all, or comma-separated (e.g. owner/a,owner/b), wildcards (owner/*)
GGHSTATS_FILTER=*

# Background sync interval (e.g. 1h, 30m)
GGHSTATS_SYNC_INTERVAL=1h

# Full sync when the process starts (true / false). Set false to serve immediately with existing SQLite data.
# GGHSTATS_SYNC_ON_STARTUP=false

# Include private repositories (true / false)
GGHSTATS_INCLUDE_PRIVATE=false

# Open default browser when ready (local try; same as gghstats run --open)
# GGHSTATS_OPEN_BROWSER=true

# If set, GET /api/repos requires header: x-api-token: <value>
GGHSTATS_API_TOKEN=

# Badge SVG at GET /api/v1/badge/{owner}/{repo} — public by default (for README img embeds)
# GGHSTATS_BADGE_PUBLIC=false
# GGHSTATS_BADGE_CACHE_SECONDS=300
# GGHSTATS_PUBLIC_URL=https://gghstats.example.com

# slog level: debug, info, warn, error
GGHSTATS_LOG_LEVEL=info

# Prometheus metrics at GET /metrics (set to false to disable)
# GGHSTATS_METRICS=true

# Optional: path to a .css file (regular file). Loaded after built-in app.css so you can simplify the neo-brutalist look or match your brand.
# Example: mount next to the DB; see contrib/themes/ for five official starter themes (incl. Bootstrap-plain).
# GGHSTATS_CUSTOM_CSS=/data/my-gghstats-theme.css

# --- CLI only (fetch / report / export; optional) ---
# GGHSTATS_REPO=owner/repo

# UI locale (dashboard only — API/CLI stay English)
# Resolution: ?lang= → cookie gghstats_locale → Accept-Language → GGHSTATS_DEFAULT_LOCALE
# Built-in: en, es, de, fr, pt-br. Add a locale: copy internal/i18n/locales/en.json → <code>.json, translate, append to ENABLED.
# See README § "Web UI languages (i18n)".
GGHSTATS_DEFAULT_LOCALE=en
GGHSTATS_ENABLED_LOCALES=en,es,de,fr,pt-br
# Spanish-first example:
# GGHSTATS_DEFAULT_LOCALE=es
# GGHSTATS_ENABLED_LOCALES=en,es,de

# --- Rate limiting (enabled by default) ---
# GGHSTATS_RATE_LIMIT_ENABLED=true
# GGHSTATS_RATE_LIMIT_REQUESTS=120
# GGHSTATS_RATE_LIMIT_PERIOD=1m
# GGHSTATS_RATE_LIMIT_BURST=20

